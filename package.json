{
  "name": "carbrate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run refresh:product-offers",
    "dev": "next dev",
    "prebuild": "npm run refresh:product-offers",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "refresh:product-offers": "node scripts/refresh-product-offers.mjs",
    "refresh:product-offers:live": "node scripts/refresh-product-offers.mjs --live",
    "refresh:product-offers:force": "node scripts/refresh-product-offers.mjs --live --force",
    "audit:product-offers": "node scripts/audit-product-offers.mjs",
    "audit:nutrition-advisor": "node --experimental-strip-types scripts/audit-nutrition-advisor.mjs"
  },
  "dependencies": {
    "next": "^16.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.5",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
